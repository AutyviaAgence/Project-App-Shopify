{% comment %}
  Xeyo — Popup d'opt-in WhatsApp (page panier)
  App Embed Block : le marchand l'active en 1 clic dans l'éditeur de thème.
  S'affiche en POPUP AUTOMATIQUE sur la page PANIER (après un délai et/ou à
  l'intention de sortie), pour capturer l'opt-in WhatsApp AVANT un éventuel
  abandon → permet la relance de panier abandonné (sur tous les plans Shopify,
  contrairement aux extensions de checkout réservées à Shopify Plus).
{% endcomment %}

<div
  id="xeyo-optin-popup"
  class="xeyo-pop"
  style="--xeyo-pop-color: {{ block.settings.accent_color }};"
  data-proxy="/apps/xeyo/optin"
  data-direct="https://app.xeyo.io/api/shopify/proxy/optin"
  data-shop="{{ shop.permanent_domain }}"
  data-delay="{{ block.settings.delay_seconds }}"
  data-exit-intent="{{ block.settings.exit_intent }}"
  data-display-mode="{{ block.settings.display_mode }}"
  data-custom-paths="{{ block.settings.custom_paths | escape }}"
  data-email="{{ customer.email | default: '' }}"
>
  <div class="xeyo-pop-card" role="dialog" aria-modal="true" aria-label="Opt-in WhatsApp">
    <button type="button" class="xeyo-pop-close" aria-label="Fermer">&times;</button>
    <p class="xeyo-pop-title">{{ block.settings.title }}</p>
    <p class="xeyo-pop-text">{{ block.settings.subtitle }}</p>
    <div class="xeyo-pop-fields">
      <select class="xeyo-pop-cc" aria-label="Indicatif pays"></select>
      <input type="tel" class="xeyo-pop-phone" placeholder="{{ block.settings.placeholder }}" />
    </div>
    <button type="button" class="xeyo-pop-submit">{{ block.settings.button }}</button>
    <p class="xeyo-pop-consent">{{ block.settings.consent }}</p>
    <p class="xeyo-pop-msg" aria-live="polite"></p>
    <a class="xeyo-pop-branding" href="https://xeyo.io" target="_blank" rel="noopener noreferrer">Powered by Xeyo.io</a>
  </div>
</div>

<style>
  /* Caché par défaut. On NE force PAS display ici (sinon il écrase le masquage).
     L'affichage est piloté par la classe .xeyo-open ajoutée par le JS. */
  #xeyo-optin-popup.xeyo-pop { display: none !important; }
  /* Overlay plein écran, centré. !important pour résister aux styles du thème. */
  #xeyo-optin-popup.xeyo-pop.xeyo-open {
    position: fixed !important; top: 0 !important; left: 0 !important;
    right: 0 !important; bottom: 0 !important; width: 100% !important; height: 100% !important;
    z-index: 2147483000 !important; margin: 0 !important;
    display: flex !important; align-items: center !important; justify-content: center !important;
    background: rgba(0,0,0,.5) !important; padding: 16px !important;
    box-sizing: border-box !important;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif !important;
  }
  #xeyo-optin-popup .xeyo-pop-card {
    position: relative !important; width: 100% !important; max-width: 400px !important;
    background: #fff !important; color: #111827 !important;
    border-radius: 16px !important; padding: 24px 22px 18px !important;
    box-shadow: 0 20px 60px rgba(0,0,0,.3) !important;
    box-sizing: border-box !important; text-align: left !important;
    animation: xeyoPopIn .25s ease-out;
  }
  @keyframes xeyoPopIn { from { transform: translateY(12px); opacity: 0 } to { transform: none; opacity: 1 } }
  #xeyo-optin-popup .xeyo-pop-close {
    position: absolute !important; top: 10px !important; right: 12px !important;
    background: none !important; border: none !important; padding: 0 !important;
    font-size: 26px !important; line-height: 1 !important; color: #9aa3ad !important; cursor: pointer !important;
  }
  #xeyo-optin-popup .xeyo-pop-title { margin: 0 0 6px !important; font-size: 18px !important; font-weight: 700 !important; color: #111827 !important; }
  #xeyo-optin-popup .xeyo-pop-text { margin: 0 0 14px !important; font-size: 14px !important; line-height: 1.4 !important; color: #4b5563 !important; }
  #xeyo-optin-popup .xeyo-pop-fields { display: flex !important; gap: 8px !important; margin: 0 0 10px !important; }
  #xeyo-optin-popup .xeyo-pop-cc {
    flex: 0 0 auto !important; max-width: 130px !important; padding: 10px 8px !important;
    border: 1px solid #d1d5db !important; border-radius: 9px !important; font-size: 14px !important;
    background: #fff !important; color: #111827 !important; box-sizing: border-box !important;
  }
  #xeyo-optin-popup .xeyo-pop-phone {
    flex: 1 1 auto !important; min-width: 0 !important; padding: 10px 12px !important;
    border: 1px solid #d1d5db !important; border-radius: 9px !important; font-size: 14px !important;
    background: #fff !important; color: #111827 !important; box-sizing: border-box !important;
  }
  #xeyo-optin-popup .xeyo-pop-submit {
    display: block !important; width: 100% !important;
    background: var(--xeyo-pop-color, #25D366) !important; color: #fff !important; border: none !important;
    border-radius: 9px !important; padding: 12px 16px !important; font-size: 15px !important;
    font-weight: 600 !important; cursor: pointer !important; box-sizing: border-box !important;
  }
  #xeyo-optin-popup .xeyo-pop-submit:disabled { opacity: .6 !important; cursor: default !important; }
  #xeyo-optin-popup .xeyo-pop-consent { margin: 12px 0 0 !important; font-size: 11px !important; line-height: 1.4 !important; color: #9aa3ad !important; }
  #xeyo-optin-popup .xeyo-pop-msg { margin: 8px 0 0 !important; font-size: 13px !important; min-height: 16px !important; }
  #xeyo-optin-popup .xeyo-pop-msg.ok { color: #15803d !important; }
  #xeyo-optin-popup .xeyo-pop-msg.err { color: #b91c1c !important; }
  #xeyo-optin-popup .xeyo-pop-branding { display: inline-block !important; margin-top: 10px !important; font-size: 10px !important; color: #9aa3ad !important; text-decoration: none !important; }
</style>

<script>
  (function () {
    var root = document.getElementById('xeyo-optin-popup');
    if (!root || root.dataset.bound) return;
    root.dataset.bound = '1';

    var card = root.querySelector('.xeyo-pop-card');
    var closeBtn = root.querySelector('.xeyo-pop-close');
    var ccSelect = root.querySelector('.xeyo-pop-cc');
    var phone = root.querySelector('.xeyo-pop-phone');
    var submit = root.querySelector('.xeyo-pop-submit');
    var msg = root.querySelector('.xeyo-pop-msg');
    var proxy = root.getAttribute('data-proxy');
    var shop = root.getAttribute('data-shop');
    var delay = parseInt(root.getAttribute('data-delay'), 10) || 8;
    var exitIntent = root.getAttribute('data-exit-intent') === 'true';

    // Indicatifs pays (drapeau + nom + indicatif). Le client choisit, il ne tape
    // que la partie locale du numéro.
    var COUNTRIES = [
      ['FR','33','🇫🇷','France'],['BE','32','🇧🇪','Belgique'],['CH','41','🇨🇭','Suisse'],
      ['LU','352','🇱🇺','Luxembourg'],['CA','1','🇨🇦','Canada'],['US','1','🇺🇸','États-Unis'],
      ['GB','44','🇬🇧','Royaume-Uni'],['DE','49','🇩🇪','Allemagne'],['ES','34','🇪🇸','Espagne'],
      ['IT','39','🇮🇹','Italie'],['PT','351','🇵🇹','Portugal'],['NL','31','🇳🇱','Pays-Bas'],
      ['IE','353','🇮🇪','Irlande'],['AT','43','🇦🇹','Autriche'],['MA','212','🇲🇦','Maroc'],
      ['DZ','213','🇩🇿','Algérie'],['TN','216','🇹🇳','Tunisie'],['SN','221','🇸🇳','Sénégal'],
      ['CI','225','🇨🇮',"Côte d'Ivoire"],['CM','237','🇨🇲','Cameroun'],['AE','971','🇦🇪','Émirats AU'],
      ['CN','86','🇨🇳','Chine'],['BR','55','🇧🇷','Brésil'],['MX','52','🇲🇽','Mexique']
    ];
    var dialByIso = {};
    COUNTRIES.forEach(function (c) {
      dialByIso[c[0]] = c[1];
      var opt = document.createElement('option');
      opt.value = c[0];
      opt.textContent = c[2] + ' +' + c[1];
      ccSelect.appendChild(opt);
    });
    // Pays par défaut : déduit de la locale du navigateur, sinon FR.
    var navIso = ((navigator.language || 'fr').split('-')[1] || '').toUpperCase();
    ccSelect.value = dialByIso[navIso] ? navIso : 'FR';

    var STORE_KEY = 'xeyo_optin_seen';
    function alreadyHandled() {
      try { return localStorage.getItem(STORE_KEY) === '1'; } catch (e) { return false; }
    }
    function markHandled() {
      try { localStorage.setItem(STORE_KEY, '1'); } catch (e) {}
    }

    if (alreadyHandled()) return;

    // Détection UNIVERSELLE du panier (marche avec page /cart classique ET tiroir
    // latéral / drawer, qui ne change pas l'URL). On vérifie le contenu réel du
    // panier via l'API Shopify /cart.js : si le client a des articles, on arme la
    // popup quelle que soit la page. C'est le vrai signal « en train d'acheter ».
    var cartHasItems = false;
    var cartTotal = null; // en unité (ex: euros), pas en centimes
    function refreshCart(cb) {
      fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
        .then(function (r) { return r.json(); })
        .then(function (c) {
          cartHasItems = (c && c.item_count > 0);
          cartTotal = (c && typeof c.total_price === 'number') ? (c.total_price / 100) : null;
          if (cb) cb();
        })
        .catch(function () { if (cb) cb(); });
    }
    // Lien de reprise du panier (universel sur Shopify).
    var cartUrl = location.origin + '/cart';

    // Condition d'affichage selon le mode choisi par le marchand :
    //   • 'cart'   : panier non vide (marche page /cart ET tiroir/drawer)
    //   • 'all'    : partout
    //   • 'custom' : uniquement si l'URL contient le chemin saisi (ex: /products,
    //                /collections/promo…). Plusieurs chemins séparés par des virgules.
    var displayMode = root.getAttribute('data-display-mode') || 'cart';
    var customPaths = (root.getAttribute('data-custom-paths') || '')
      .split(',').map(function (s) { return s.trim(); }).filter(Boolean);
    function urlMatchesCustom() {
      var path = location.pathname + location.search;
      return customPaths.some(function (p) { return path.indexOf(p) !== -1; });
    }
    function cartGateOk() {
      if (displayMode === 'all') return true;
      if (displayMode === 'custom') return urlMatchesCustom();
      return cartHasItems; // 'cart' (défaut)
    }

    var shown = false;
    function show() {
      if (shown || alreadyHandled() || !cartGateOk()) return;
      shown = true;
      root.classList.add('xeyo-open');
      try { phone.focus(); } catch (e) {}
    }
    function hide() { root.classList.remove('xeyo-open'); }

    // Charge l'état du panier au démarrage (et le rafraîchit périodiquement, car
    // le client peut ajouter un article après le chargement de la page).
    refreshCart();
    var cartPoll = setInterval(function () { refreshCart(); }, 15000);

    // Numéro déjà opt-in (cette session ou une précédente) : permet d'armer la
    // relance panier au DÉPART, même si l'opt-in a été fait avant l'ajout au panier.
    var optedInPhone = null;
    try { optedInPhone = localStorage.getItem('xeyo_optin_phone') || null; } catch (e) {}

    // ── Déclenchement intelligent (façon Cartloop/Privy) ────────────────────
    // On n'affiche JAMAIS dès l'arrivée. La popup se déclenche sur un vrai signal
    // d'ENGAGEMENT, avec un délai de sécurité minimum pour ne pas spammer :
    //   • Desktop : exit-intent (souris qui remonte vers la fermeture)
    //   • Mobile  : scroll significatif (le client parcourt la page)
    //   • Filet   : après un délai plus long, si rien ne s'est déclenché
    var MIN_DELAY = (delay || 8) * 1000;            // garde-fou avant tout déclenchement
    var FALLBACK = Math.max(MIN_DELAY * 2, 18000);  // dernier recours
    var armedAt = Date.now();
    var isMobile = matchMedia('(pointer: coarse)').matches || innerWidth < 768;

    function armed() { return Date.now() - armedAt >= MIN_DELAY; }

    // Filet de dernier recours : si aucun signal, on finit par afficher.
    var fallbackTimer = setTimeout(show, FALLBACK);

    if (!isMobile && exitIntent) {
      // Exit-intent desktop : la souris quitte par le haut de la fenêtre.
      document.addEventListener('mouseout', function (e) {
        if (armed() && e.clientY <= 0 && !e.relatedTarget) show();
      });
    }

    // Scroll significatif (surtout mobile, mais utile partout) : le client a
    // parcouru ~40% de la page → signal d'intérêt.
    function onScroll() {
      if (!armed()) return;
      var sc = window.scrollY || document.documentElement.scrollTop || 0;
      var h = (document.documentElement.scrollHeight - window.innerHeight) || 1;
      if (sc / h >= 0.4) show();
    }
    window.addEventListener('scroll', onScroll, { passive: true });

    function cleanup() { clearTimeout(fallbackTimer); clearInterval(cartPoll); }
    closeBtn.addEventListener('click', function () { hide(); markHandled(); cleanup(); });
    root.addEventListener('click', function (e) { if (e.target === root) { hide(); markHandled(); cleanup(); } });

    function doSubmit(val, custEmail) {
      submit.disabled = true;
      msg.className = 'xeyo-pop-msg'; msg.textContent = 'Enregistrement…';
      var payload = {
        phone: val,
        email: custEmail || undefined,
        marketing: true,
        // Panier en cours → relance "panier abandonné" si pas de commande.
        cart_url: cartHasItems ? cartUrl : undefined,
        cart_total: cartTotal != null ? cartTotal : undefined
      };
      // Log de debug (visible dans la console) pour vérifier ce qui est envoyé.
      try { console.log('[Xeyo opt-in] POST optin', payload); } catch (e) {}
      fetch(proxy + '?shop=' + encodeURIComponent(shop), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
        .then(function (r) { return r.json(); })
        .then(function (res) {
          try { console.log('[Xeyo opt-in] optin réponse', res); } catch (e) {}
          if (res && res.ok) {
            msg.className = 'xeyo-pop-msg ok';
            msg.textContent = 'C\'est noté ! Vous recevrez le suivi sur WhatsApp.';
            // On mémorise le numéro opt-in : si le client ajoute un article APRÈS
            // puis quitte sans commander, on arme la relance panier à la sortie
            // (cf. armCartRecoveryOnExit). Couvre le cas opt-in d'abord, panier ensuite.
            try { localStorage.setItem('xeyo_optin_phone', val); } catch (e) {}
            optedInPhone = val;
            markHandled();
            setTimeout(hide, 1600);
          } else {
            msg.className = 'xeyo-pop-msg err';
            msg.textContent = (res && res.error) ? res.error : 'Erreur, réessayez.';
            submit.disabled = false;
          }
        })
        .catch(function () {
          msg.className = 'xeyo-pop-msg err'; msg.textContent = 'Erreur réseau.'; submit.disabled = false;
        });
    }

    submit.addEventListener('click', function () {
      var dial = dialByIso[ccSelect.value] || '33';
      var local = (phone.value || '').replace(/[^0-9]/g, '').replace(/^0+/, '');
      if (local.length < 6) {
        msg.className = 'xeyo-pop-msg err'; msg.textContent = 'Numéro invalide.'; return;
      }
      var val = dial + local; // E.164 sans le "+", le serveur ne garde que les chiffres
      var custEmail = root.getAttribute('data-email') || '';
      // On RAFRAÎCHIT le panier juste avant l'envoi (évite un état périmé : le
      // cart_url n'était pas transmis si la 1re lecture async n'avait pas fini).
      refreshCart(function () { doSubmit(val, custEmail); });
    });

    // ── RELANCE PANIER AU DÉPART (le vrai déclencheur) ──────────────────────
    // Le signal d'abandon, c'est le client qui QUITTE la page avec un panier non
    // vide après avoir donné son numéro. On envoie un "beacon" (survit à la
    // fermeture de page). Le serveur dédoublonne par contact + tranche de temps.
    //
    // Pour ne pas dépendre du poll (15s) au moment du départ, on garde le panier
    // à jour via un poll rapproché (5s) et une copie "dernière connue".
    var lastCartUrl = null;
    var lastCartTotal = null;
    var lastCartHasItems = false;
    function snapshotCart() {
      lastCartUrl = cartUrl;
      lastCartTotal = cartTotal;
      lastCartHasItems = cartHasItems;
    }
    setInterval(function () { refreshCart(snapshotCart); }, 5000);
    refreshCart(snapshotCart);

    var exitArmed = false;
    function armCartRecoveryOnExit() {
      var hasItems = lastCartHasItems || cartHasItems;
      var theUrl = lastCartUrl || cartUrl;
      if (exitArmed) return;
      if (!optedInPhone) { try { console.log('[Xeyo opt-in] départ ignoré : pas de numéro opt-in'); } catch (e) {} return; }
      if (!hasItems) { try { console.log('[Xeyo opt-in] départ ignoré : panier vide'); } catch (e) {} return; }
      exitArmed = true; // une seule fois par page
      var payload = {
        phone: optedInPhone,
        email: root.getAttribute('data-email') || undefined,
        marketing: true,
        cart_url: theUrl,
        cart_total: (lastCartTotal != null ? lastCartTotal : cartTotal),
        source: 'exit'
      };
      try { console.log('[Xeyo opt-in] beacon panier (départ)', payload); } catch (e) {}
      // IMPORTANT : on vise l'URL DIRECTE (app.xeyo.io), pas le proxy Shopify
      // relatif. Le proxy fait une redirection, or sendBeacon pendant un
      // déchargement de page abandonne les requêtes redirigées → échec silencieux.
      var url = (root.getAttribute('data-direct') || (proxy)) + '?shop=' + encodeURIComponent(shop);
      var bodyStr = JSON.stringify(payload);
      // sendBeacon en text/plain (Content-Type CORS-safe → plus fiable). Le
      // serveur parse le JSON quel que soit le Content-Type.
      try {
        var blob = new Blob([bodyStr], { type: 'text/plain;charset=UTF-8' });
        if (navigator.sendBeacon && navigator.sendBeacon(url, blob)) return;
      } catch (e) {}
      try {
        fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: bodyStr, keepalive: true });
      } catch (e) {}
    }
    window.addEventListener('pagehide', armCartRecoveryOnExit);
    window.addEventListener('beforeunload', armCartRecoveryOnExit);
    document.addEventListener('visibilitychange', function () {
      if (document.visibilityState === 'hidden') armCartRecoveryOnExit();
    });
    // Expose le handler pour pouvoir le tester manuellement depuis la console :
    //   window.__xeyoExit()
    try { window.__xeyoExit = armCartRecoveryOnExit; } catch (e) {}
    try { console.log('[Xeyo opt-in] relance départ armée (listeners en place)'); } catch (e) {}
  })();
</script>

{% schema %}
{
  "name": "Xeyo — Popup opt-in",
  "target": "body",
  "settings": [
    {
      "type": "paragraph",
      "content": "Popup d'opt-in WhatsApp sur la page panier (avant l'abandon). Connectez votre WhatsApp dans Xeyo pour l'activer. Personnalisez ci-dessous."
    },
    { "type": "text", "id": "title", "label": "Titre", "default": "📦 Suivez votre commande sur WhatsApp" },
    { "type": "text", "id": "subtitle", "label": "Sous-titre", "default": "Recevez le suivi de votre commande et nos offres exclusives." },
    { "type": "text", "id": "placeholder", "label": "Placeholder du numéro", "default": "6 12 34 56 78" },
    { "type": "text", "id": "button", "label": "Texte du bouton", "default": "Recevoir sur WhatsApp" },
    { "type": "text", "id": "consent", "label": "Mention de consentement", "default": "En validant, j'accepte de recevoir des messages WhatsApp (suivi + offres). STOP pour me désabonner." },
    { "type": "paragraph", "content": "La popup s'affiche sur un signal d'engagement (intention de sortie sur ordinateur, défilement sur mobile), jamais dès l'arrivée. Le délai ci-dessous est un minimum de sécurité avant tout affichage." },
    { "type": "range", "id": "delay_seconds", "label": "Délai minimum avant affichage (secondes)", "min": 3, "max": 30, "step": 1, "default": 8 },
    { "type": "checkbox", "id": "exit_intent", "label": "Déclencher à l'intention de sortie (ordinateur)", "default": true },
    {
      "type": "select",
      "id": "display_mode",
      "label": "Où afficher la popup",
      "options": [
        { "value": "cart", "label": "Quand le panier n'est pas vide (recommandé)" },
        { "value": "all", "label": "Sur toutes les pages" },
        { "value": "custom", "label": "Sur des pages précises (ci-dessous)" }
      ],
      "default": "cart"
    },
    { "type": "text", "id": "custom_paths", "label": "Pages précises (si « pages précises »)", "info": "Chemins d'URL séparés par des virgules. Ex : /cart, /products, /collections/promo", "default": "/cart" },
    { "type": "color", "id": "accent_color", "label": "Couleur", "default": "#25D366" }
  ]
}
{% endschema %}
