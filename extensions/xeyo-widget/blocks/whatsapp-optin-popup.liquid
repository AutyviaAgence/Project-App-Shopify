{% comment %}
  Xeyo — Popup d'opt-in WhatsApp (page panier)
  App Embed Block : le marchand l'active en 1 clic dans l'éditeur de thème.
  S'affiche en POPUP AUTOMATIQUE sur la page PANIER (après un délai et/ou à
  l'intention de sortie), pour capturer l'opt-in WhatsApp AVANT un éventuel
  abandon → permet la relance de panier abandonné (sur tous les plans Shopify,
  contrairement aux extensions de checkout réservées à Shopify Plus).
{% endcomment %}

<div
  id="xeyo-optin-popup"
  class="xeyo-pop"
  style="--xeyo-pop-color: {{ block.settings.accent_color }}; display:none;"
  data-proxy="/apps/xeyo/optin"
  data-shop="{{ shop.permanent_domain }}"
  data-delay="{{ block.settings.delay_seconds }}"
  data-exit-intent="{{ block.settings.exit_intent }}"
  data-cart-only="{{ block.settings.cart_only }}"
>
  <div class="xeyo-pop-card" role="dialog" aria-modal="true" aria-label="Opt-in WhatsApp">
    <button type="button" class="xeyo-pop-close" aria-label="Fermer">&times;</button>
    <p class="xeyo-pop-title">{{ block.settings.title }}</p>
    <p class="xeyo-pop-text">{{ block.settings.subtitle }}</p>
    <div class="xeyo-pop-fields">
      <select class="xeyo-pop-cc" aria-label="Indicatif pays"></select>
      <input type="tel" class="xeyo-pop-phone" placeholder="{{ block.settings.placeholder }}" />
    </div>
    <button type="button" class="xeyo-pop-submit">{{ block.settings.button }}</button>
    <p class="xeyo-pop-consent">{{ block.settings.consent }}</p>
    <p class="xeyo-pop-msg" aria-live="polite"></p>
    <a class="xeyo-pop-branding" href="https://xeyo.io" target="_blank" rel="noopener noreferrer">Powered by Xeyo.io</a>
  </div>
</div>

<style>
  /* Overlay plein écran, centré. !important pour résister aux styles du thème. */
  #xeyo-optin-popup.xeyo-pop {
    position: fixed !important; top: 0 !important; left: 0 !important;
    right: 0 !important; bottom: 0 !important; width: 100% !important; height: 100% !important;
    z-index: 2147483000 !important; margin: 0 !important;
    display: flex !important; align-items: center !important; justify-content: center !important;
    background: rgba(0,0,0,.5) !important; padding: 16px !important;
    box-sizing: border-box !important;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif !important;
  }
  #xeyo-optin-popup .xeyo-pop-card {
    position: relative !important; width: 100% !important; max-width: 400px !important;
    background: #fff !important; color: #111827 !important;
    border-radius: 16px !important; padding: 24px 22px 18px !important;
    box-shadow: 0 20px 60px rgba(0,0,0,.3) !important;
    box-sizing: border-box !important; text-align: left !important;
    animation: xeyoPopIn .25s ease-out;
  }
  @keyframes xeyoPopIn { from { transform: translateY(12px); opacity: 0 } to { transform: none; opacity: 1 } }
  #xeyo-optin-popup .xeyo-pop-close {
    position: absolute !important; top: 10px !important; right: 12px !important;
    background: none !important; border: none !important; padding: 0 !important;
    font-size: 26px !important; line-height: 1 !important; color: #9aa3ad !important; cursor: pointer !important;
  }
  #xeyo-optin-popup .xeyo-pop-title { margin: 0 0 6px !important; font-size: 18px !important; font-weight: 700 !important; color: #111827 !important; }
  #xeyo-optin-popup .xeyo-pop-text { margin: 0 0 14px !important; font-size: 14px !important; line-height: 1.4 !important; color: #4b5563 !important; }
  #xeyo-optin-popup .xeyo-pop-fields { display: flex !important; gap: 8px !important; margin: 0 0 10px !important; }
  #xeyo-optin-popup .xeyo-pop-cc {
    flex: 0 0 auto !important; max-width: 130px !important; padding: 10px 8px !important;
    border: 1px solid #d1d5db !important; border-radius: 9px !important; font-size: 14px !important;
    background: #fff !important; color: #111827 !important; box-sizing: border-box !important;
  }
  #xeyo-optin-popup .xeyo-pop-phone {
    flex: 1 1 auto !important; min-width: 0 !important; padding: 10px 12px !important;
    border: 1px solid #d1d5db !important; border-radius: 9px !important; font-size: 14px !important;
    background: #fff !important; color: #111827 !important; box-sizing: border-box !important;
  }
  #xeyo-optin-popup .xeyo-pop-submit {
    display: block !important; width: 100% !important;
    background: var(--xeyo-pop-color, #25D366) !important; color: #fff !important; border: none !important;
    border-radius: 9px !important; padding: 12px 16px !important; font-size: 15px !important;
    font-weight: 600 !important; cursor: pointer !important; box-sizing: border-box !important;
  }
  #xeyo-optin-popup .xeyo-pop-submit:disabled { opacity: .6 !important; cursor: default !important; }
  #xeyo-optin-popup .xeyo-pop-consent { margin: 12px 0 0 !important; font-size: 11px !important; line-height: 1.4 !important; color: #9aa3ad !important; }
  #xeyo-optin-popup .xeyo-pop-msg { margin: 8px 0 0 !important; font-size: 13px !important; min-height: 16px !important; }
  #xeyo-optin-popup .xeyo-pop-msg.ok { color: #15803d !important; }
  #xeyo-optin-popup .xeyo-pop-msg.err { color: #b91c1c !important; }
  #xeyo-optin-popup .xeyo-pop-branding { display: inline-block !important; margin-top: 10px !important; font-size: 10px !important; color: #9aa3ad !important; text-decoration: none !important; }
</style>

<script>
  (function () {
    var root = document.getElementById('xeyo-optin-popup');
    if (!root || root.dataset.bound) return;
    root.dataset.bound = '1';

    var card = root.querySelector('.xeyo-pop-card');
    var closeBtn = root.querySelector('.xeyo-pop-close');
    var ccSelect = root.querySelector('.xeyo-pop-cc');
    var phone = root.querySelector('.xeyo-pop-phone');
    var submit = root.querySelector('.xeyo-pop-submit');
    var msg = root.querySelector('.xeyo-pop-msg');
    var proxy = root.getAttribute('data-proxy');
    var shop = root.getAttribute('data-shop');
    var delay = parseInt(root.getAttribute('data-delay'), 10) || 8;
    var exitIntent = root.getAttribute('data-exit-intent') === 'true';
    var cartOnly = root.getAttribute('data-cart-only') === 'true';

    // Indicatifs pays (drapeau + nom + indicatif). Le client choisit, il ne tape
    // que la partie locale du numéro.
    var COUNTRIES = [
      ['FR','33','🇫🇷','France'],['BE','32','🇧🇪','Belgique'],['CH','41','🇨🇭','Suisse'],
      ['LU','352','🇱🇺','Luxembourg'],['CA','1','🇨🇦','Canada'],['US','1','🇺🇸','États-Unis'],
      ['GB','44','🇬🇧','Royaume-Uni'],['DE','49','🇩🇪','Allemagne'],['ES','34','🇪🇸','Espagne'],
      ['IT','39','🇮🇹','Italie'],['PT','351','🇵🇹','Portugal'],['NL','31','🇳🇱','Pays-Bas'],
      ['IE','353','🇮🇪','Irlande'],['AT','43','🇦🇹','Autriche'],['MA','212','🇲🇦','Maroc'],
      ['DZ','213','🇩🇿','Algérie'],['TN','216','🇹🇳','Tunisie'],['SN','221','🇸🇳','Sénégal'],
      ['CI','225','🇨🇮',"Côte d'Ivoire"],['CM','237','🇨🇲','Cameroun'],['AE','971','🇦🇪','Émirats AU'],
      ['CN','86','🇨🇳','Chine'],['BR','55','🇧🇷','Brésil'],['MX','52','🇲🇽','Mexique']
    ];
    var dialByIso = {};
    COUNTRIES.forEach(function (c) {
      dialByIso[c[0]] = c[1];
      var opt = document.createElement('option');
      opt.value = c[0];
      opt.textContent = c[2] + ' +' + c[1];
      ccSelect.appendChild(opt);
    });
    // Pays par défaut : déduit de la locale du navigateur, sinon FR.
    var navIso = ((navigator.language || 'fr').split('-')[1] || '').toUpperCase();
    ccSelect.value = dialByIso[navIso] ? navIso : 'FR';

    var STORE_KEY = 'xeyo_optin_seen';
    function alreadyHandled() {
      try { return localStorage.getItem(STORE_KEY) === '1'; } catch (e) { return false; }
    }
    function markHandled() {
      try { localStorage.setItem(STORE_KEY, '1'); } catch (e) {}
    }

    // Ne s'affiche que sur la page panier (sauf si cart_only = false).
    var isCart = /\/cart(\b|\/|\?|$)/.test(location.pathname + location.search);
    if (cartOnly && !isCart) return;
    if (alreadyHandled()) return;

    var shown = false;
    function show() {
      if (shown || alreadyHandled()) return;
      shown = true;
      root.style.display = 'flex';
      phone.focus();
    }
    function hide() { root.style.display = 'none'; }

    // Déclenchement : après un délai…
    var timer = setTimeout(show, delay * 1000);
    // …et/ou à l'intention de sortie (souris qui quitte le haut de la page).
    if (exitIntent) {
      document.addEventListener('mouseout', function (e) {
        if (e.clientY <= 0 && !e.relatedTarget) show();
      });
    }

    closeBtn.addEventListener('click', function () { hide(); markHandled(); clearTimeout(timer); });
    root.addEventListener('click', function (e) { if (e.target === root) { hide(); markHandled(); } });

    submit.addEventListener('click', function () {
      var dial = dialByIso[ccSelect.value] || '33';
      var local = (phone.value || '').replace(/[^0-9]/g, '').replace(/^0+/, '');
      if (local.length < 6) {
        msg.className = 'xeyo-pop-msg err'; msg.textContent = 'Numéro invalide.'; return;
      }
      var val = dial + local; // E.164 sans le "+", le serveur ne garde que les chiffres
      submit.disabled = true;
      msg.className = 'xeyo-pop-msg'; msg.textContent = 'Enregistrement…';
      fetch(proxy + '?shop=' + encodeURIComponent(shop), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone: val, marketing: true })
      })
        .then(function (r) { return r.json(); })
        .then(function (res) {
          if (res && res.ok) {
            msg.className = 'xeyo-pop-msg ok';
            msg.textContent = 'C\'est noté ! Vous recevrez le suivi sur WhatsApp.';
            markHandled();
            setTimeout(hide, 1600);
          } else {
            msg.className = 'xeyo-pop-msg err';
            msg.textContent = (res && res.error) ? res.error : 'Erreur, réessayez.';
            submit.disabled = false;
          }
        })
        .catch(function () {
          msg.className = 'xeyo-pop-msg err'; msg.textContent = 'Erreur réseau.'; submit.disabled = false;
        });
    });
  })();
</script>

{% schema %}
{
  "name": "Xeyo — Popup opt-in",
  "target": "body",
  "settings": [
    {
      "type": "paragraph",
      "content": "Popup d'opt-in WhatsApp sur la page panier (avant l'abandon). Connectez votre WhatsApp dans Xeyo pour l'activer. Personnalisez ci-dessous."
    },
    { "type": "text", "id": "title", "label": "Titre", "default": "📦 Suivez votre commande sur WhatsApp" },
    { "type": "text", "id": "subtitle", "label": "Sous-titre", "default": "Recevez le suivi de votre commande et nos offres exclusives." },
    { "type": "text", "id": "placeholder", "label": "Placeholder du numéro", "default": "6 12 34 56 78" },
    { "type": "text", "id": "button", "label": "Texte du bouton", "default": "Recevoir sur WhatsApp" },
    { "type": "text", "id": "consent", "label": "Mention de consentement", "default": "En validant, j'accepte de recevoir des messages WhatsApp (suivi + offres). STOP pour me désabonner." },
    { "type": "range", "id": "delay_seconds", "label": "Délai avant affichage (secondes)", "min": 2, "max": 30, "step": 1, "default": 8 },
    { "type": "checkbox", "id": "exit_intent", "label": "Afficher aussi à l'intention de sortie", "default": true },
    { "type": "checkbox", "id": "cart_only", "label": "Uniquement sur la page panier", "default": true },
    { "type": "color", "id": "accent_color", "label": "Couleur", "default": "#25D366" }
  ]
}
{% endschema %}
