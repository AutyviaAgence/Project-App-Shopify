# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# migration scripts (contiennent des secrets — ne pas committer)
migration/

# fichier temporaire de message de commit
commit_msg.txt

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# backups
backup_*.sql
supabase/.temp/
.git-rewrite/

# Dépendances des extensions Shopify
extensions/*/node_modules/
extensions/**/node_modules/
.shopify/
extensions/*/dist/

# k6 load test artifact
scripts/loadtest/last-run-summary.json

# Fichiers de workspace VS Code (locaux)
*.code-workspace

# Videos (demo App Store, captures) — jamais versionnees
*.mp4
